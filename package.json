{
  "name": "crosstown",
  "version": "0.1.0",
  "description": "A dev-only floating toolbar for tuning page transitions, with six built-in presets.",
  "license": "MIT",
  "author": "Charles (0xchsh)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xchsh/crosstown.git"
  },
  "homepage": "https://github.com/0xchsh/crosstown",
  "bugs": "https://github.com/0xchsh/crosstown/issues",
  "keywords": [
    "nextjs",
    "react",
    "framer-motion",
    "page-transitions",
    "animation",
    "dev-tools",
    "toolbar"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "workspaces": [
    "examples/*"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "example:dev": "npm run dev --workspace=next-app-example",
    "example:build": "npm run build --workspace=next-app-example"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "framer-motion": ">=11",
    "next": ">=14"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "framer-motion": "^11.0.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "size-limit": "^11.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "size-limit": [
    {
      "name": "Crosstown (runtime, prod)",
      "path": "dist/index.js",
      "limit": "8 KB",
      "ignore": [
        "react",
        "react-dom",
        "framer-motion"
      ]
    }
  ]
}
